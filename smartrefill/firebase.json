
{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "runtime": "nodejs20",
      "region": "us-central1",
      "environment": {
        "APP_BASE_URL": "https://smartrefill.io",
        "SUPPORT_EMAIL": "support@smartrefill.io"
      }
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "location": "asia-east2"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "source": ".",
    "site": "smartrefill",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/__/auth/**",
        "destination": "/__/auth/**"
      },
      {
        "source": "**",
        "function": "server"
      }
    ],
    "appAssociation": "AUTO"
  }
}
